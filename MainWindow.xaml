<Window x:Class="MeatCafeWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meat Cafe" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#b84f5b" Offset="0"/>
                        <GradientStop Color="#ab2b3a" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#8b1a2b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8,4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#fdf2f4"/>
            <Setter Property="BorderBrush" Value="#e08791"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#fffafa"/>
            <Setter Property="BorderBrush" Value="#e08791"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="Foreground" Value="#ab2b3a"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#e08791" Offset="0.0"/>
                <GradientStop Color="#f8e1e4" Offset="0.5"/>
                <GradientStop Color="#e08791" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel x:Name="pnlOrderNumber" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Welcome to Meat Cafe!" FontSize="28" Foreground="#ab2b3a" FontWeight="Bold"
                       FontFamily="Segoe UI" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Enter your order number (or 0 to exit):" VerticalAlignment="Center" 
                           FontSize="14" Margin="0,0,10,0"/>
                <TextBox x:Name="txtOrderNumber" Width="150" MaxLength="10" VerticalAlignment="Center"
                         PreviewTextInput="TxtOrderNumber_PreviewTextInput"/>
            </StackPanel>
            <Button Content="Start" Width="100" Margin="0,10" HorizontalAlignment="Center" Click="BtnStart_Click"/>
        </StackPanel>

        <Grid x:Name="grdMain" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="#f2c7cc">
                <TextBlock FontWeight="Bold" FontSize="16" Text="Meat Cafe" Foreground="#5e1220" 
                           FontFamily="Segoe UI"/>
                <TextBlock Text=" | Order #:" Margin="10,0,0,0" Foreground="#5e1220" 
                           FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblOrderNumber" VerticalAlignment="Center" Foreground="#5e1220" 
                           FontSize="14" FontWeight="SemiBold"/>
                <Button x:Name="btnBack" Content="← Back to Main Menu" Visibility="Collapsed"
                        Click="BtnBack_Click" Margin="20,0,0,0" Background="#b84f5b"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="10">
                <StackPanel x:Name="pnlMainMenu">
                    <TextBlock Text="Main Menu" FontSize="22" Foreground="#ab2b3a" FontWeight="Bold" 
                               FontFamily="Segoe UI" Margin="0,0,0,15"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Button Content="1. Food Menu" Height="40" Click="BtnFoodMenu_Click"/>
                            <Button Content="2. Drink Menu" Height="40" Click="BtnDrinkMenu_Click"/>
                            <Button Content="3. View Order" Height="40" Click="BtnViewOrder_Click"/>
                            <Button Content="4. Remove Item" Height="40" Click="BtnRemoveItem_Click"/>
                            <Button Content="5. Clear All" Height="40" Click="BtnClearAll_Click"/>
                            <Button Content="6. Save to file" Height="40" Click="BtnSaveToFile_Click"/>
                            <Button Content="7. Load from file (Unable until you save file)" Height="40" Click="BtnLoadFromFile_Click"/>
                            <Button Content="8. Place Order" Height="40" Click="BtnPlaceOrder_Click"/>
                            <Button Content="0. Exit" Height="40" Click="BtnExit_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel x:Name="pnlMenuItems" Visibility="Collapsed">
                    <TextBlock x:Name="lblMenuTitle" Style="{StaticResource HeaderStyle}"/>
                    <ListBox x:Name="lstMenuItems" SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                               Foreground="#3b0d14" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                               Margin="8,4,0,4"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Info}" 
                                               Foreground="#ab2b3a" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                                               HorizontalAlignment="Right" Margin="0,4,20,4" MinWidth="80"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="Transparent" BorderThickness="1"
                                                    CornerRadius="4" Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#e08791"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#f5c6cb"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <Button Content="Add Selected Item" Height="35" Margin="0,10" Click="BtnAddMenuItem_Click"/>
                </StackPanel>

                <StackPanel x:Name="pnlViewOrder" Visibility="Collapsed">
                    <TextBlock Text="Current Order" Style="{StaticResource HeaderStyle}"/>
                    <ListBox x:Name="lstOrderView">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                               Foreground="#3b0d14" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                               Margin="8,4,0,4"/>
                                    <TextBlock Grid.Column="1"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Info}" 
                                               Foreground="#ab2b3a" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                                               HorizontalAlignment="Right" Margin="0,4,20,4" MinWidth="80"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel x:Name="pnlRemoveItem" Visibility="Collapsed">
                    <TextBlock Text="Select item to remove" Style="{StaticResource HeaderStyle}"/>
                    <ListBox x:Name="lstRemoveItems" SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                               Foreground="#3b0d14" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                               Margin="8,4,0,4"/>
                                    <TextBlock Grid.Column="1"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Info}" 
                                               Foreground="#ab2b3a" VerticalAlignment="Center"
                                               FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                                               HorizontalAlignment="Right" Margin="0,4,20,4" MinWidth="80"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Remove Selected" Height="35" Margin="0,10" Click="BtnRemoveSelected_Click"/>
                </StackPanel>

                <StackPanel x:Name="pnlLoadOrder" Visibility="Collapsed">
                    <TextBlock Text="Enter order number to load:" Margin="0,0,0,10" FontSize="15" 
                               FontFamily="Segoe UI" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="txtLoadOrderNumber" Width="150" MaxLength="10"
                                 PreviewTextInput="TxtOrderNumber_PreviewTextInput"/>
                        <Button Content="Load" Margin="10,0,0,0" Click="BtnLoadOrder_Click"/>
                    </StackPanel>
                </StackPanel>

                <Grid x:Name="pnlPlaceOrder" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="pnlPlaceOrderStep1">
                        <TextBlock Text="Place Order" Style="{StaticResource HeaderStyle}"/>
                        <ListBox x:Name="lstPlaceOrderItems" MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                                   Foreground="#3b0d14" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                                   Margin="8,4,0,4"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Info}" 
                                                   Foreground="#ab2b3a" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                                                   HorizontalAlignment="Right" Margin="0,4,20,4" MinWidth="80"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="lblNetTotal" FontWeight="Bold" Foreground="#ab2b3a" Margin="0,10"
                                   FontSize="16" FontFamily="Segoe UI"/>
                        <Button Content="Proceed to Tip" Height="35" Click="BtnPlaceOrderProceed_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="pnlPlaceOrderStep2" Visibility="Collapsed">
                        <TextBlock Text="Leave tip?" FontSize="16" Margin="0,0,0,5" Foreground="#ab2b3a" 
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbTipYes" Content="Yes" GroupName="tip" Checked="TipOptionChanged"
                                         Foreground="#5e1220"/>
                            <RadioButton x:Name="rbTipNo" Content="No" GroupName="tip" Checked="TipOptionChanged"
                                         Foreground="#5e1220" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel x:Name="pnlTipDetails" Visibility="Collapsed" Margin="0,10">
                            <TextBlock Text="Tip type:" Foreground="#5e1220" FontWeight="SemiBold" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <RadioButton x:Name="rbPercent" Content="Percent" GroupName="tipType" Foreground="#5e1220"/>
                                <RadioButton x:Name="rbFixed" Content="Fixed amount" GroupName="tipType"
                                             Foreground="#5e1220" Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Enter value:" Margin="0,5,0,0" Foreground="#5e1220" 
                                       FontWeight="SemiBold" FontSize="14"/>
                            <TextBox x:Name="txtTipValue" Width="100"/>
                        </StackPanel>
                        <Button Content="Calculate Final" Height="35" Margin="0,10" Click="BtnCalculateFinal_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="pnlPlaceOrderStep3" Visibility="Collapsed">
                        <TextBlock Text="--- Final Bill ---" FontWeight="Bold" Foreground="#ab2b3a" 
                                   FontSize="18" FontFamily="Segoe UI"/>
                        <ListBox x:Name="lstFinalBillItems" MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" 
                                                   Foreground="#3b0d14" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                                                   Margin="8,4,0,4"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Info}" 
                                                   Foreground="#ab2b3a" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                                                   HorizontalAlignment="Right" Margin="0,4,20,4" MinWidth="80"
                                                   TextAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="lblFinalNet" Margin="0,5" Foreground="#5e1220" FontSize="14" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="lblFinalTip" Foreground="#5e1220" FontSize="14" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="lblFinalGST" Foreground="#5e1220" FontSize="14" FontFamily="Segoe UI"/>
                        <Separator Margin="0,5"/>
                        <TextBlock x:Name="lblFinalTotal" FontWeight="Bold" Foreground="#ab2b3a" 
                                   FontSize="16" FontFamily="Segoe UI"/>
                        <TextBlock Text="Choose mode:" Margin="0,10,0,5" Foreground="#ab2b3a" FontWeight="Bold" 
                                   FontSize="15" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbTakeaway" Content="1. Takeaway" GroupName="mode" Foreground="#5e1220"/>
                            <RadioButton x:Name="rbDinein" Content="2. Dine-in" GroupName="mode"
                                         Foreground="#5e1220" Margin="10,0,0,0"/>
                        </StackPanel>
                        <Button Content="Place Order" Height="35" Margin="0,10" Click="BtnFinalPlaceOrder_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>